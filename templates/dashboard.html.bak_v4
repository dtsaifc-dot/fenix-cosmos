<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>FENIX PRO v3</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    :root{
      --bg:#050505;
      --panel:#0d0d0d;
      --border:#2b251d;
      --gold:#d4af37;
      --bronze:#cd7f32;
      --text:#eadfb9;
      --muted:#a88c58;
      --green:#4fd37f;
      --red:#a12b2b;
      --cyan:#62d9ff;
      --shadow:0 10px 28px rgba(0,0,0,.42);
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      background:
        radial-gradient(circle at 18% 10%, rgba(212,175,55,.05), transparent 20%),
        radial-gradient(circle at 82% 18%, rgba(205,127,50,.04), transparent 18%),
        linear-gradient(180deg,#050505 0%,#080808 100%);
      color:var(--text);
      font-family:Inter,Segoe UI,Arial,sans-serif;
      min-height:100vh;
      overflow-x:hidden;
    }
    .phoenix-bg{
      position:fixed; inset:0; pointer-events:none; z-index:0; opacity:.11;
      background-repeat:no-repeat; background-position:center 53%; background-size:700px;
      background-image:url("data:image/svg+xml;utf8,\
      <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1000 1000'>\
        <g fill='none' stroke='%23d4af37' stroke-width='18' stroke-linecap='round' stroke-linejoin='round'>\
          <path d='M500 160 C560 230, 580 315, 500 390 C420 315, 440 230, 500 160 Z' fill='%23d4af37' opacity='0.16'/>\
          <path d='M500 235 C492 292, 494 360, 500 430'/>\
          <path d='M500 430 C548 520, 590 615, 640 760'/>\
          <path d='M500 430 C452 520, 410 615, 360 760'/>\
          <path d='M486 412 C335 345, 235 275, 120 170'/>\
          <path d='M514 412 C665 345, 765 275, 880 170'/>\
          <path d='M430 392 C280 418, 170 414, 70 350'/>\
          <path d='M570 392 C720 418, 830 414, 930 350'/>\
          <path d='M438 560 C360 620, 290 700, 240 820'/>\
          <path d='M562 560 C640 620, 710 700, 760 820'/>\
          <path d='M450 780 C485 745, 495 700, 500 640'/>\
          <path d='M550 780 C515 745, 505 700, 500 640'/>\
        </g>\
      </svg>");
    }
    .wrap{position:relative; z-index:1; max-width:1500px; margin:0 auto; padding:16px;}
    .topbar{
      display:grid; grid-template-columns:1fr auto 1fr; align-items:center; margin-bottom:14px;
    }
    .brand{display:flex; align-items:center; gap:10px; font-size:22px; font-weight:900; color:#7fe9db}
    .motto-wrap{display:flex; align-items:center; justify-content:center; gap:14px}
    .motto{color:var(--gold); font-size:18px; font-weight:900; letter-spacing:3px}
    .caesar{
      width:40px; height:40px; opacity:.85; background-size:contain; background-repeat:no-repeat; background-position:center;
      background-image:url("data:image/svg+xml;utf8,\
      <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 128 128'>\
        <path fill='%23d4af37' d='M64 12c16 0 28 10 32 24l4 16c8 4 12 12 12 22 0 12-8 22-20 26l-4 16H40l-4-18C22 94 16 84 16 72c0-10 6-18 14-22l2-12C36 22 48 12 64 12zm-8 26c-4 0-8 2-10 6 6 2 10 8 10 14v8c0 8 6 14 14 14h10c6 0 12-2 16-6-2 12-10 22-28 22-26 0-38-16-38-34 0-14 10-24 26-24z'/>\
      </svg>");
    }
    .clock{text-align:right; color:#7fe9db; font-size:26px; font-weight:900}
    .grid{display:grid; grid-template-columns:1.05fr 1fr 1fr; gap:14px; align-items:start}
    .card{
      background:linear-gradient(180deg, rgba(13,13,13,.96), rgba(8,8,8,.98));
      border:1px solid rgba(212,175,55,.12);
      border-radius:16px;
      padding:14px;
      box-shadow:var(--shadow);
    }
    .section-title{color:#9ec7ff; font-size:11px; text-transform:uppercase; letter-spacing:1.1px; margin-bottom:12px; font-weight:800}
    .signal-main{display:flex; flex-direction:column; align-items:center; gap:8px; margin-top:4px}
    .signal-word{font-size:50px; line-height:1; font-weight:900}
    .up{color:var(--green)} .down{color:#d35a5a}
    .muted-state{color:#c2b58d}
    .confidence-big{font-size:22px; font-weight:900; color:var(--gold)}
    .status-line{font-size:14px; font-weight:800; color:#c8b37a}
    .regime-line{font-size:13px; font-weight:800; color:#8ed3ff}
    .countdown{font-size:50px; line-height:1; font-weight:900; color:var(--cyan); margin:2px 0 4px}
    .rows{display:grid; grid-template-columns:1fr auto; gap:8px 10px; margin-top:14px; font-size:14px}
    .label{color:var(--muted)} .value{font-weight:800; text-align:right}
    .metric-row{margin-bottom:12px}
    .metric-head{display:flex; justify-content:space-between; font-size:13px; margin-bottom:5px}
    .bar-track{width:100%; height:10px; border-radius:999px; overflow:hidden; background:#171717; border:1px solid rgba(212,175,55,.10)}
    .bar-fill{height:100%; border-radius:999px; transition:width .25s ease}
    .bar-gold{background:linear-gradient(90deg,var(--bronze),var(--gold))}
    .bar-green{background:linear-gradient(90deg,#257246,var(--green))}
    .bar-red{background:linear-gradient(90deg,#591616,var(--red))}
    .bar-cyan{background:linear-gradient(90deg,#245b70,var(--cyan))}
    .stats-grid{display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:14px}
    .mini{background:#090909; border:1px solid rgba(212,175,55,.10); border-radius:12px; padding:10px; text-align:center}
    .mini .k{font-size:11px; color:var(--muted); text-transform:uppercase}
    .mini .v{font-size:22px; font-weight:900; color:var(--gold)}
    .last15{display:flex; gap:6px; flex-wrap:wrap; margin-top:8px}
    .dot{width:20px; height:20px; border-radius:5px; display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:900; border:1px solid rgba(255,255,255,.08)}
    .dot.win{background:rgba(79,211,127,.16); color:var(--green)}
    .dot.loss{background:rgba(122,31,31,.28); color:#ff8d8d}
    .dot.pending{background:rgba(98,217,255,.10); color:var(--cyan)}
    .dot.skip{background:rgba(180,180,180,.10); color:#ddd}
    .reasons-list{margin:0; padding-left:18px; color:var(--text); font-size:13px; line-height:1.5}
    .history-card{margin-top:14px}
    .table-wrap{overflow:auto; border-radius:12px; border:1px solid rgba(212,175,55,.10); background:#090909}
    table{width:100%; border-collapse:collapse; min-width:1200px}
    th,td{padding:9px 8px; border-bottom:1px solid rgba(255,255,255,.04); font-size:12px; text-align:left; white-space:nowrap}
    th{color:var(--gold); background:#101010; position:sticky; top:0; z-index:1}
    .tag{display:inline-block; min-width:62px; text-align:center; padding:4px 8px; border-radius:999px; font-weight:900; font-size:11px; border:1px solid rgba(255,255,255,.08)}
    .tag.up{background:rgba(79,211,127,.15)}
    .tag.down{background:rgba(122,31,31,.26); color:#ff9b9b}
    .tag.no{background:rgba(180,180,180,.12); color:#ddd}
    .result-win{color:var(--green);font-weight:900}
    .result-loss{color:#ff8d8d;font-weight:900}
    .result-pending{color:var(--cyan);font-weight:900}
    .result-skip{color:#ddd;font-weight:900}
    .footer-note{margin-top:8px; color:var(--muted); font-size:12px}
    @media (max-width:1200px){
      .grid{grid-template-columns:1fr}
      .topbar{grid-template-columns:1fr; gap:10px}
      .brand,.motto-wrap,.clock{justify-content:center; text-align:center}
    }
  </style>
</head>
<body>
  <div class="phoenix-bg"></div>
  <div class="wrap">
    <div class="topbar">
      <div class="brand">⚡ FENIX Dashboard</div>
      <div class="motto-wrap">
        <div class="caesar"></div>
        <div class="motto">ALEA IACTA EST</div>
      </div>
      <div class="clock" id="clock">--:--:--</div>
    </div>

    <div class="grid">
      <div class="card">
        <div class="section-title">Final Signal</div>
        <div class="signal-main">
          <div id="signalWord" class="signal-word muted-state">COLLECTING</div>
          <div id="statusLine" class="status-line">LIVE STATE</div>
          <div id="regimeLine" class="regime-line">-</div>
          <div id="confidenceBig" class="confidence-big">0%</div>
          <div class="bar-track" style="width:100%;max-width:240px;">
            <div id="confidenceBar" class="bar-fill bar-gold" style="width:0%"></div>
          </div>
          <div id="countdown" class="countdown">0:00</div>
        </div>

        <div class="rows">
          <div class="label">Target candle</div><div class="value" id="targetCandle">-</div>
          <div class="label">Signal created</div><div class="value" id="generatedAt">-</div>
          <div class="label">Score</div><div class="value" id="scoreValue">-</div>
          <div class="label">Live confidence</div><div class="value" id="liveConfidence">-</div>
        </div>
      </div>

      <div class="card">
        <div class="section-title">Order Flow</div>

        <div class="metric-row">
          <div class="metric-head"><span>Buy</span><span id="buyPctVal">-</span></div>
          <div class="bar-track"><div id="buyPctBar" class="bar-fill bar-green" style="width:0%"></div></div>
        </div>

        <div class="metric-row">
          <div class="metric-head"><span>Sell</span><span id="sellPctVal">-</span></div>
          <div class="bar-track"><div id="sellPctBar" class="bar-fill bar-red" style="width:0%"></div></div>
        </div>

        <div class="rows">
          <div class="label">Trades in OF window</div><div class="value" id="tradesCount">-</div>
          <div class="label">Buy volume</div><div class="value" id="buyQty">-</div>
          <div class="label">Sell volume</div><div class="value" id="sellQty">-</div>
          <div class="label">Flow</div><div class="value" id="flowBias">-</div>
          <div class="label">30s / 10s / 3s</div><div class="value" id="windowState">-</div>
        </div>
      </div>

      <div class="card">
        <div class="section-title">Depth</div>

        <div class="metric-row">
          <div class="metric-head"><span>Imbalance</span><span id="imbalanceVal">-</span></div>
          <div class="bar-track"><div id="imbalanceBar" class="bar-fill bar-cyan" style="width:0%"></div></div>
        </div>

        <div class="metric-row">
          <div class="metric-head"><span>Bid/Ask ratio</span><span id="ratioVal">-</span></div>
          <div class="bar-track"><div id="ratioBar" class="bar-fill bar-gold" style="width:0%"></div></div>
        </div>

        <div class="rows">
          <div class="label">Bid vol</div><div class="value" id="bidVol">-</div>
          <div class="label">Ask vol</div><div class="value" id="askVol">-</div>
          <div class="label">Levels</div><div class="value" id="levelsVal">-</div>
          <div class="label">Price</div><div class="value" id="lastPrice">-</div>
          <div class="label">Micro bias</div><div class="value" id="microBiasVal">-</div>
        </div>
      </div>
    </div>

    <div class="grid" style="margin-top:14px;">
      <div class="card">
        <div class="section-title">Cum Delta + Trend</div>

        <div class="metric-row">
          <div class="metric-head"><span>Cum delta</span><span id="deltaStrengthVal">-</span></div>
          <div class="bar-track"><div id="deltaStrengthBar" class="bar-fill bar-cyan" style="width:0%"></div></div>
        </div>

        <div class="rows">
          <div class="label">Last cum delta</div><div class="value" id="cumDeltaVal">-</div>
          <div class="label">Slope</div><div class="value" id="slopeVal">-</div>
          <div class="label">Delta trend 7</div><div class="value" id="trend7Val">-</div>
          <div class="label">Delta trend 20</div><div class="value" id="trend20Val">-</div>
          <div class="label">Divergence</div><div class="value" id="divergenceVal">-</div>
          <div class="label">Regime</div><div class="value" id="liveRegimeVal">-</div>
        </div>
      </div>

      <div class="card">
        <div class="section-title">Statistics / Winrate</div>

        <div class="stats-grid">
          <div class="mini"><div class="k">Total</div><div class="v" id="statTotal">0</div></div>
          <div class="mini"><div class="k">Wins</div><div class="v" id="statWins">0</div></div>
          <div class="mini"><div class="k">Up WR</div><div class="v" id="statUpWr">0%</div></div>
          <div class="mini"><div class="k">Down WR</div><div class="v" id="statDownWr">0%</div></div>
        </div>

        <div class="metric-row">
          <div class="metric-head"><span>Overall winrate</span><span id="statWinrate">0%</span></div>
          <div class="bar-track"><div id="overallWrBar" class="bar-fill bar-gold" style="width:0%"></div></div>
        </div>

        <div class="section-title" style="margin-top:10px;">Last 15 Results</div>
        <div id="last15" class="last15"></div>
        <div class="footer-note" id="last15Summary">-</div>
      </div>

      <div class="card">
        <div class="section-title">Reasons</div>
        <ul id="reasonsList" class="reasons-list"></ul>
      </div>
    </div>

    <div class="card history-card">
      <div class="section-title">Signal History</div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Signal Time</th>
              <th>Target Candle</th>
              <th>Display</th>
              <th>Status</th>
              <th>Regime</th>
              <th>Conf</th>
              <th>Score</th>
              <th>Buy%</th>
              <th>Depth</th>
              <th>Cum Δ</th>
              <th>Open</th>
              <th>Close</th>
              <th>Actual</th>
              <th>Result</th>
            </tr>
          </thead>
          <tbody id="historyBody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    function setClock(){
      const d = new Date();
      document.getElementById('clock').textContent = d.toLocaleTimeString('en-GB', {hour12:false});
    }
    setClock();
    setInterval(setClock, 1000);

    function fmt(v, digits=2){
      if(v === null || v === undefined || Number.isNaN(Number(v))) return '-';
      return Number(v).toFixed(digits);
    }

    function resultClass(r){
      if(r === 'WIN') return 'result-win';
      if(r === 'LOSS') return 'result-loss';
      if(r === 'SKIP') return 'result-skip';
      return 'result-pending';
    }

    function tagClass(display){
      if(display === 'UP') return 'up';
      if(display === 'DOWN') return 'down';
      return 'no';
    }

    function flowBias(buy, sell){
      if(buy > sell) return 'BUY';
      if(sell > buy) return 'SELL';
      return 'NEUTRAL';
    }

    function signedBar(v, maxAbs=1){
      const n = Math.abs(Number(v || 0));
      return Math.max(0, Math.min(100, (n / maxAbs) * 100));
    }

    async function refresh(){
      const res = await fetch('/api/dashboard');
      const data = await res.json();

      const s = data.signal_locked || {};
      const p = data.signal_preview || {};
      const f = data.features_live || {};
      const history = data.history || [];
      const stats = data.stats || {};
      const meta = data.meta || {};

      const display = (s.display_signal || 'COLLECTING').toUpperCase();
      const direction = (s.direction || '').toUpperCase();
      const signalWord = document.getElementById('signalWord');

      signalWord.textContent = display;
      if(display === 'UP'){
        signalWord.className = 'signal-word up';
      } else if(display === 'DOWN'){
        signalWord.className = 'signal-word down';
      } else {
        signalWord.className = 'signal-word muted-state';
      }

      document.getElementById('statusLine').textContent = s.status || '-';
      document.getElementById('regimeLine').textContent = s.regime || '-';

      const conf = Number(s.confidence || 0);
      document.getElementById('confidenceBig').textContent = fmt(conf,1) + '%';
      document.getElementById('confidenceBar').style.width = Math.max(2, conf) + '%';

      const sec = Number(s.seconds_left || 0);
      const mm = Math.floor(sec / 60);
      const ss = Math.floor(sec % 60);
      document.getElementById('countdown').textContent = `${mm}:${String(ss).padStart(2,'0')}`;

      document.getElementById('targetCandle').textContent = s.target_open_utc || '-';
      document.getElementById('generatedAt').textContent = s.generated_at || '-';
      document.getElementById('scoreValue').textContent = fmt(s.score, 2);
      document.getElementById('liveConfidence').textContent = fmt(conf, 1) + '%';

      const buyPct = Number(f.buy_pct || 0);
      const sellPct = Number(f.sell_pct || 0);
      document.getElementById('buyPctVal').textContent = fmt(buyPct,1) + '%';
      document.getElementById('sellPctVal').textContent = fmt(sellPct,1) + '%';
      document.getElementById('buyPctBar').style.width = buyPct + '%';
      document.getElementById('sellPctBar').style.width = sellPct + '%';
      document.getElementById('tradesCount').textContent = f.trades_count ?? '-';
      document.getElementById('buyQty').textContent = fmt(f.buy_qty, 4);
      document.getElementById('sellQty').textContent = fmt(f.sell_qty, 4);
      document.getElementById('flowBias').textContent = flowBias(buyPct, sellPct);
      document.getElementById('windowState').textContent =
        `${fmt(f.w30?.buy_pct ?? 50,0)} / ${fmt(f.w10?.buy_pct ?? 50,0)} / ${fmt(f.w3?.buy_pct ?? 50,0)}`;

      const imbSigned = Number(f.imbalance || 0);
      const imbPct = Number(f.imbalance_pct || 50);
      const ratio = Number(f.bid_ask_ratio || 0);
      document.getElementById('imbalanceVal').textContent = fmt(imbSigned,3) + ' / ' + fmt(imbPct,1) + '%';
      document.getElementById('ratioVal').textContent = fmt(ratio,2);
      document.getElementById('imbalanceBar').style.width = Math.max(2, imbPct) + '%';
      document.getElementById('ratioBar').style.width = Math.max(2, Math.min(100, ratio * 18)) + '%';
      document.getElementById('bidVol').textContent = fmt(f.bid_vol,2);
      document.getElementById('askVol').textContent = fmt(f.ask_vol,2);
      document.getElementById('levelsVal').textContent = f.levels ?? '-';
      document.getElementById('lastPrice').textContent = fmt(f.last_price,2);
      document.getElementById('microBiasVal').textContent = fmt(f.micro_bias_bps,2) + ' bps';

      const cumDelta = Number(f.cum_delta || 0);
      const slope = Number(f.slope || 0);
      document.getElementById('cumDeltaVal').textContent = fmt(cumDelta,4);
      document.getElementById('slopeVal').textContent = fmt(slope,4);
      document.getElementById('trend7Val').textContent = f.delta_trend_7 || '-';
      document.getElementById('trend20Val').textContent = f.delta_trend_20 || '-';
      document.getElementById('divergenceVal').textContent = f.divergence || '-';
      document.getElementById('liveRegimeVal').textContent = f.regime_live || '-';
      document.getElementById('deltaStrengthVal').textContent = fmt(cumDelta,4);
      document.getElementById('deltaStrengthBar').style.width = Math.max(2, signedBar(cumDelta, 1.5)) + '%';

      document.getElementById('statTotal').textContent = stats.total ?? 0;
      document.getElementById('statWins').textContent = stats.wins ?? 0;
      document.getElementById('statUpWr').textContent = fmt(stats.up_wr || 0,1) + '%';
      document.getElementById('statDownWr').textContent = fmt(stats.down_wr || 0,1) + '%';
      document.getElementById('statWinrate').textContent = fmt(stats.winrate || 0,1) + '%';
      document.getElementById('overallWrBar').style.width = Math.max(2, Number(stats.winrate || 0)) + '%';

      const last15 = stats.last15 || [];
      const last15El = document.getElementById('last15');
      last15El.innerHTML = '';
      let last15Wins = 0;
      let last15Resolved = 0;

      last15.forEach(item => {
        const div = document.createElement('div');
        const r = item.result || 'PENDING';
        div.className = 'dot ' + (
          r === 'WIN' ? 'win' :
          r === 'LOSS' ? 'loss' :
          r === 'SKIP' ? 'skip' : 'pending'
        );
        div.textContent = r === 'WIN' ? '✓' : r === 'LOSS' ? '✕' : r === 'SKIP' ? '–' : '•';
        last15El.appendChild(div);
        if(r === 'WIN' || r === 'LOSS'){
          last15Resolved++;
          if(r === 'WIN') last15Wins++;
        }
      });

      const last15Pct = last15Resolved ? (last15Wins / last15Resolved * 100) : 0;
      document.getElementById('last15Summary').textContent =
        `${last15Wins}/${last15Resolved || last15.length} wins in last 15 (${fmt(last15Pct,1)}%)`;

      const reasons = s.reasons || [];
      const reasonsList = document.getElementById('reasonsList');
      reasonsList.innerHTML = '';
      reasons.forEach(r => {
        const li = document.createElement('li');
        li.textContent = r;
        reasonsList.appendChild(li);
      });

      const tbody = document.getElementById('historyBody');
      tbody.innerHTML = '';
      history.forEach(row => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${row.signal_time || '-'}</td>
          <td>${row.target_candle || '-'}</td>
          <td><span class="tag ${tagClass((row.display_signal || row.signal || '').toUpperCase())}">${row.display_signal || row.signal || '-'}</span></td>
          <td>${row.status ?? '-'}</td>
          <td>${row.regime ?? '-'}</td>
          <td>${row.confidence ?? '-'}</td>
          <td>${row.score ?? '-'}</td>
          <td>${row.buy_pct ?? '-'}</td>
          <td>${row.imbalance ?? '-'}</td>
          <td>${row.cum_delta ?? '-'}</td>
          <td>${row.open ?? '-'}</td>
          <td>${row.close ?? '-'}</td>
          <td>${row.actual ?? '-'}</td>
          <td class="${resultClass(row.result)}">${row.result ?? '-'}</td>
        `;
        tbody.appendChild(tr);
      });
    }

    refresh();
    setInterval(refresh, 1000);
  </script>
</body>
</html>
